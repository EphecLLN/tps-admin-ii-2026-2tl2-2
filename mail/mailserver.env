# SSL Type - Crucial pour Let's Encrypt
SSL_TYPE=letsencrypt

# Nom de domaine
DOMAINNAME=l2-2.ephec-ti.be

# FQDN complet
OVERRIDE_HOSTNAME=mail.l2-2.ephec-ti.be

# Enable SSL/TLS
ENABLE_SSL=yes

# Pour la livraison des emails
ENABLE_POSTFIX_VIRTUAL_TRANSPORT=yes

# Fuseau horaire
TZ=Europe/Brussels
